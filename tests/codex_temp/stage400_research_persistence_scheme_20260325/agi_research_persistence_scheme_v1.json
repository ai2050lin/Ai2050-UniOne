{
  "scheme_id": "agi_research_persistence_scheme_v1",
  "focus": "为后续理论突破积累拼图，不预设某个理论主核",
  "core_principles": [
    "原始数据优先，理论后置",
    "追加式保存，不覆盖原始记录",
    "研究结论与原始数据分层保存",
    "所有分析结果必须可追溯到原始阶段、脚本、输出目录",
    "可视化数据必须引用研究数据，不独立漂移",
    "允许多套提取算法并存，不强行提前统一"
  ],
  "two_tracks": {
    "agi_research_track": {
      "goal": "持续积累参数级、神经元级、层级运行级拼图",
      "data_classes": [
        "原始参数映射数据",
        "原始层级运行数据",
        "原始提取结果",
        "候选机制结构",
        "候选理论与判据"
      ]
    },
    "visualization_track": {
      "goal": "把研究资产映射到当前28个layer主视图，不让展示层脱离研究数据",
      "data_classes": [
        "layer骨架配置",
        "神经元点位数据",
        "参数位节点数据",
        "动画轨迹数据",
        "右侧分析面板映射数据",
        "可视化场景清单"
      ]
    }
  },
  "storage_layers": [
    {
      "layer_id": "raw_capture",
      "name": "原始抓取层",
      "content": [
        "layer_index",
        "token_index",
        "dim_index",
        "parameter_ids",
        "activation_value",
        "hook_name",
        "source_model",
        "source_prompt",
        "timestamp"
      ],
      "write_mode": "append_only"
    },
    {
      "layer_id": "raw_research_rows",
      "name": "原始研究行层",
      "content": [
        "summary.json 中的 _rows 行束",
        "refined_rows.jsonl 精炼行",
        "结构标签",
        "字段签名",
        "来源阶段",
        "输出目录"
      ],
      "write_mode": "append_only"
    },
    {
      "layer_id": "analysis_products",
      "name": "分析结果层",
      "content": [
        "提取算法结果",
        "模式统计",
        "结构链结果",
        "跨模型共识结果",
        "局部子链结果"
      ],
      "write_mode": "versioned"
    },
    {
      "layer_id": "theory_candidates",
      "name": "理论候选层",
      "content": [
        "候选结构清单",
        "候选原理清单",
        "突破标准",
        "判伪条件"
      ],
      "write_mode": "versioned"
    },
    {
      "layer_id": "visualization_assets",
      "name": "可视化资产层",
      "content": [
        "layer主视图映射",
        "神经元点位清单",
        "参数位节点清单",
        "动画轨迹清单",
        "按钮状态与交互清单",
        "3D 场景清单"
      ],
      "write_mode": "versioned"
    },
    {
      "layer_id": "audit_and_provenance",
      "name": "审计与溯源层",
      "content": [
        "脚本路径",
        "输出目录",
        "生成时间",
        "生成命令",
        "依赖输入文件",
        "关联场景文件"
      ],
      "write_mode": "append_only"
    }
  ],
  "recommended_layout": {
    "research_raw": "research/gpt5/data/raw/",
    "research_rows": "research/gpt5/data/rows/",
    "analysis": "research/gpt5/data/analysis/",
    "theory": "research/gpt5/data/theory_candidates/",
    "visualization": "research/gpt5/data/visualization/",
    "audit": "research/gpt5/data/audit/"
  },
  "primary_entities": [
    {
      "entity": "raw_event",
      "must_fields": [
        "event_id",
        "model_key",
        "layer_index",
        "token_index",
        "dim_index",
        "activation_value",
        "source_stage"
      ]
    },
    {
      "entity": "research_row",
      "must_fields": [
        "row_id",
        "stage_id",
        "category",
        "field_signature",
        "source_summary_path",
        "source_output_dir"
      ]
    },
    {
      "entity": "analysis_result",
      "must_fields": [
        "analysis_id",
        "algorithm_id",
        "input_scope",
        "score",
        "support_rows",
        "source_stage_ids"
      ]
    },
    {
      "entity": "visual_node",
      "must_fields": [
        "node_id",
        "node_type",
        "layer_index",
        "dim_index",
        "source_entity_id",
        "scene_id"
      ]
    },
    {
      "entity": "theory_candidate",
      "must_fields": [
        "candidate_id",
        "statement",
        "support_analysis_ids",
        "support_row_ids",
        "status"
      ]
    }
  ],
  "link_rules": [
    "任何理论候选都必须反向链接到 analysis_result 和 research_row",
    "任何 visual_node 都必须反向链接到原始 research_row 或 raw_event",
    "任何 analysis_result 都必须记录算法编号、输入范围和来源阶段",
    "任何覆盖原始数据的聚合结果都必须保留 source_row_count 和 source_ids"
  ],
  "anti_preset_rules": [
    "原始数据目录中不得写入带结论导向的理论标签",
    "理论候选不得反向改写原始 research_row",
    "可视化场景不得独立发明字段，必须来自 raw_event 或 analysis_result",
    "不同算法结果允许同时存在，禁止只保留单一赢家算法"
  ],
  "current_files_to_treat_as_core_sources": [
    "tests/codex_temp/stage313_*/*summary.json",
    "tests/codex_temp/stage314_*/*summary.json",
    "tests/codex_temp/stage359_*/*refined_rows.jsonl",
    "tests/codex_temp/stage360_*/*refined_rows.jsonl",
    "tests/codex_temp/stage366_*/*summary.json",
    "tests/codex_temp/stage380_*/*summary.json",
    "tests/codex_temp/stage381_*/*summary.json",
    "tests/codex_temp/stage399_*/*summary.json",
    "frontend/src/blueprint/data/layer_parameter_state_overlay_v1.js"
  ],
  "next_implementation_targets": [
    "把 layer_index、token_index、parameter_ids 统一补进原始事件格式",
    "把 refined_rows.jsonl 升级成带 entity_id 的可链接数据",
    "把前端3D节点全部改成引用 visual_node 而不是手写散点",
    "把理论候选改成单独目录，不与分析结果混存"
  ]
}